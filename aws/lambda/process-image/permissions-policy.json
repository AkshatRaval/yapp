{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRawImages",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::yapp-media-production/raw/images/*"
    },
    {
      "Sid": "WriteProcessedImages",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::yapp-media-production/processed/images/*"
    },
    {
      "Sid": "ReadSupabaseServiceSecret",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue"],
      "Resource": "arn:aws:secretsmanager:ap-south-1:292535187723:secret:yapp/supabase-service*"
    },
    {
      "Sid": "WriteLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
