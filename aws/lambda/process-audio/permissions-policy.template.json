{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AudioBucketReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::YOUR_BUCKET/raw/audio/*",
        "arn:aws:s3:::YOUR_BUCKET/processed/audio/*"
      ]
    },
    {
      "Sid": "ReadSupabaseSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "YOUR_SECRET_ARN"
    },
    {
      "Sid": "WriteCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
